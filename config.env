CONFIG_ENV=config.env

KERNEL_SOURCE=https://github.com/SpeechlessMatt/android_kernel_xiaomi_earth
KERNEL_SOURCE_BRANCH=12.1
KERNEL_CONFIG=earth_defconfig
KERNEL_IMAGE_NAME=Image.gz
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=false
EXTRA_CMDS:LD=ld.lld

# Clang
## Custom
USE_CUSTOM_CLANG=false
CUSTOM_CLANG_SOURCE=
CUSTOM_CLANG_BRANCH=

### if your set USE CUSTOM CLANG to false than DO NOT CHANGE CUSTOM CMDS
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-

## AOSP
CLANG_BRANCH=master-kernel-build-2021
CLANG_VERSION=r416183b

# GCC
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true
USE_CUSTOM_GCC_64=false
CUSTOM_GCC_64_SOURCE=
CUSTOM_GCC_64_BRANCH=
CUSTOM_GCC_64_BIN=aarch64-linux-android-
USE_CUSTOM_GCC_32=false
CUSTOM_GCC_32_SOURCE=
CUSTOM_GCC_32_BRANCH=
CUSTOM_GCC_32_BIN=arm-linux-androideabi-

# KernelSU flags
ENABLE_KERNELSU=true
KERNELSU_TAG=
KSU_EXPECTED_SIZE=
KSU_EXPECTED_HASH=

# Configuration
DISABLE-LTO=true
DISABLE_CC_WERROR=true
ADD_KPROBES_CONFIG=true
ADD_OVERLAYFS_CONFIG=true

# Ccache
ENABLE_CCACHE=true

# DTBO image
NEED_DTBO=false

# Build boot images
BUILD_BOOT_IMG=false
SOURCE_BOOT_IMAGE=https://coding-net-production-file-1257242599.cos.ap-shanghai.myqcloud.com/08bfd5b2-f008-416a-8fe5-a67175c7f657.img?sign=q-sign-algorithm%3Dsha1%26q-ak%3DAKIDEyIA1nnMmaT-v37RFxW7hT_s8lswh1y071-blQ43avuM0JwVzI2vBaJNKbRJaJMS%26q-sign-time%3D1706350042%3B1706351842%26q-key-time%3D1706350042%3B1706351842%26q-header-list%3Dhost%26q-url-param-list%3Dresponse-content-disposition%26q-signature%3D33635d3478359baf55939c726a20833231bade7b&response-content-disposition=attachment%3Bfilename%2A%3Dutf-8%27%27boot.img&x-cos-security-token=MnMjpXIxf9jonQ59dhVAFnL6XL26cFUaf8fcc870ff06e834fc14525c41187eb0UtbZH_KmzboG1iGLe0BL7gRaD_dM-zNLWXeGhWjc9TWfPnfwUB1m00pGUu6ZdJXglsnwHwFRlklCF9W7a5KJ9wh5JULlCW8fxFuoru9IuKjQFGxZgNHhlIR0UTNeBYe_R4_ma6rY7uHp7wBazwMJMlAj-DamvC0_X_puFgtT2ToC_468Cy65XErlCD2hy_Kpn3JGfFI9-stjGou0Ga-O4wGs3d0KN9j7Dcs9gl2mJwk2L3hrGSsCRtw6bVmuyF1FzlnqDDlpl0YE3aDkAYlbujIJ3v1O11WRPw8M2BBveOvmOkBd5CTuW1e1inc-2CQc
